VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ==========================================================================
# GSTIN lookup provider (server-side only — never prefix with VITE_)
# Pick one: swipe (default, free) | sandbox (paid, high-quality)
# Adding a new provider: drop a Provider entry in lookup-gstin/index.ts + vite.config.ts.
# ==========================================================================

GSTIN_PROVIDER=swipe

# --- swipe (developers.getswipe.in — free Partner API) ---
SWIPE_AUTH_TOKEN=YOUR_SWIPE_JWT_TOKEN
SWIPE_API_BASE=https://app.getswipe.in/api/partner

# --- sandbox (api.sandbox.co.in — paid monthly plan) ---
# SANDBOX_API_KEY=
# SANDBOX_API_SECRET=
# SANDBOX_API_BASE=https://api.sandbox.co.in
